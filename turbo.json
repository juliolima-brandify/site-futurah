{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_*",
        "PAYLOAD_SECRET",
        "DATABASE_URL",
        "BLOB_READ_WRITE_TOKEN",
        "AI_GATEWAY_API_KEY",
        "AI_GATEWAY_MODEL",
        "TRACKER_API_URL",
        "TRACKER_API_TOKEN",
        "LEADS_INGEST_TOKEN",
        "LEADS_INGEST_URL",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "NEXTJS_ENV"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "deploy": {
      "cache": false,
      "dependsOn": ["build"]
    }
  }
}
