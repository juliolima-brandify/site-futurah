# apps/augustofelipe — env vars
# Copie para .env.local e preencha. .env.local é gitignored.

# ---- Ingestão de leads -------------------------------------------------------

# Bearer aceito por https://www.futurah.co/api/leads/ingest. Mesmo valor que está
# no projeto Vercel `site-futurah`. Rotacionar = atualizar nos dois em sincronia.
LEADS_INGEST_TOKEN=

# Opcional. Override do endpoint de ingestão (útil pra preview/staging).
# Default: https://www.futurah.co/api/leads/ingest
# LEADS_INGEST_URL=

# ---- Análise de perfil (Action do Custom GPT) --------------------------------

# Token da conta Apify do Julio. Usado server-side pra scraping de perfil + posts
# do Instagram (actors apify~instagram-profile-scraper e apify~instagram-scraper).
# Rotacionável no painel Apify. NUNCA commitar; guardar como secret no Vercel.
APIFY_TOKEN=

# Chave que protege GET /api/analise-perfil. O mesmo valor vai na config da Action
# do Custom GPT (Authentication -> API Key -> Bearer). Gere um valor longo aleatório.
ANALISE_API_KEY=

# Conn string do Postgres do Payload (mesmo DB do site-futurah). Usado pelo gate
# de escassez (1 análise gratuita por email, tabela analise_usage). Use o pooler
# do Supabase (porta 6543). Sem isso, o gate libera tudo (fail-open) e o limite
# de 1 por aluno NÃO é aplicado. Mesma senha do site-futurah — rotacionar em sincronia.
DATABASE_URL=

# ---- Tracker -----------------------------------------------------------------

# Tracker Worker (packages/tracker-worker). Consumido pelo SDK no browser.
NEXT_PUBLIC_TRACKER_ENDPOINT=https://t.augustofelipe.com/e

# Meta Pixel ID — CAPI V1 server-side via Worker + pixel dedup.
NEXT_PUBLIC_META_PIXEL_ID=

# ---- Email (Resend) ----------------------------------------------------------

# Chave Resend EXCLUSIVA do augustofelipe (NÃO compartilhar com site-futurah).
# Sem isso, o email de notificação do onboarding Creator Elite é pulado.
RESEND_API_KEY=

# Opcional. Default: Creator Elite <analise@futurah.co>. Domínio precisa estar
# verificado no Resend.
# RESEND_FROM_EMAIL=

# Opcional. Destinatário do email de onboarding Creator Elite.
# Default: augustofelipe@futurah.co
# CREATOR_ELITE_NOTIFY_EMAIL=
