# Copie este arquivo para .env e preencha as chaves

# Chave da API Anthropic (Claude)
# Crie em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Chave da API OpenAI (Whisper)
# Crie em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Opcional: arquivo de cookies do Instagram (formato Netscape)
# Necessário para perfis privados ou se yt-dlp for bloqueado
# Exporte com extensão "Get cookies.txt LOCALLY" no Chrome
INSTAGRAM_COOKIES_FILE=cookies.txt
