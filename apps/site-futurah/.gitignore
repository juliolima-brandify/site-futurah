# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
build_err*.log
*_report.txt

# env files (todos)
.env
.env.*
!.env.example

# vercel
.vercel

# opennext (Cloudflare Workers)
.open-next

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code (local agent state: worktrees, tool results, launch config)
.claude/

# QA/debug artifacts (HTML/log dumps gerados por scripts de teste locais)
.qa-*

# scratch local (extração de PDFs de cliente, scripts throwaway, dumps intermediários)
/tmp/

# scripts/ NÃO é gitignored. Seeds idempotentes (seed-tenants) e migrations
# one-off ficam tracked pra que bootstrap de DB novo seja reproduzível.
# Antes de versionar um script novo, conferir que ele não tem secrets
# hardcoded — sempre ler de process.env (DATABASE_URL etc.).
# Logs/artefatos locais ignorados abaixo.
/scripts/.test.log
/scripts/*.log

.vercel

.env*.local
