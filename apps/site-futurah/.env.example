# Database / Payload
DATABASE_URL=
PAYLOAD_SECRET=
BLOB_READ_WRITE_TOKEN=

# Tracker (Worker em packages/tracker-worker)
# Endpoint público de ingestão consumido pelo SDK no browser.
NEXT_PUBLIC_TRACKER_ENDPOINT=https://t.futurah.co/e
# API de leitura usada pelo dashboard /admin/tracking (server-side).
TRACKER_API_URL=https://t.futurah.co
TRACKER_API_TOKEN=

# CTA da análise — URL da agenda comercial (Calendly etc.).
# OPCIONAL: sem isso, os CTAs caem em mailto:contato@futurah.co.
# Lida no momento da geração e gravada no snapshot da análise (imutável depois).
NEXT_PUBLIC_AGENDA_URL=

# Email transacional (Resend) — disparo quando análise é aprovada no admin.
# OPCIONAL em dev: sem RESEND_API_KEY o admin segue funcionando, só não envia email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Futurah <analise@futurah.co>
